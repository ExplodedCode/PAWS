<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PAWS.Views.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="14" MaxWidth="560" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button
                    x:Name="BackButton"
                    Click="OnBackClicked"
                    Style="{StaticResource NavigationBackButtonNormalStyle}"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Back"
                    Visibility="Collapsed" />
                <TextBlock Text="Add a Proton account" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock
                Text="Sign in on Proton's website — passkeys and 2FA are supported, and your password is never entered into PAWS. Then choose a folder to sync."
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <InfoBar x:Name="ErrorBar" Severity="Error" IsOpen="False" IsClosable="True" />

            <!-- Step 1: sign in via browser -->
            <TextBlock Text="1 · Sign in" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="SignInButton" Content="Sign in with Proton" Style="{StaticResource AccentButtonStyle}" Click="OnSignInClicked" />
                <ProgressRing x:Name="SignInBusy" IsActive="False" Width="22" Height="22" VerticalAlignment="Center" />
                <TextBlock x:Name="SignInStatus" VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
            <InfoBar x:Name="SignInInfo" IsOpen="False" IsClosable="False" Severity="Informational" />

            <!-- Step 2: folder to sync (enabled after sign-in) -->
            <ContentControl x:Name="FolderSection" IsEnabled="False" Opacity="0.5" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="14">
                    <TextBlock Text="2 · Folder to sync" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
                    <TextBox x:Name="LabelBox" Header="Label for this account (optional)" PlaceholderText="e.g. Work or Personal" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LocalFolderBox" Header="Local folder" PlaceholderText="C:\Users\you\ProtonSync" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Browse…" VerticalAlignment="Bottom" Click="OnBrowseClicked" />
                    </Grid>
                    <TextBox x:Name="RemotePathBox" Header="Proton Drive folder" Text="/" PlaceholderText="/Backup/Desktop" />
                    <ComboBox x:Name="ModeBox" Header="Sync mode" HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem Content="On-demand — placeholders, download when opened" />
                        <ComboBoxItem Content="Full sync — keep every file local" />
                        <ComboBoxItem Content="Cloud-only — download only when pinned" />
                    </ComboBox>
                    <Button x:Name="FinishButton" Content="Add account" Style="{StaticResource AccentButtonStyle}" Click="OnFinishClicked" HorizontalAlignment="Right" Margin="0,12,0,0" />
                </StackPanel>
            </ContentControl>
        </StackPanel>
    </ScrollViewer>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PAWS.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="16" MaxWidth="640" HorizontalAlignment="Center">
            <TextBlock Text="PAWS" Style="{StaticResource TitleTextBlockStyle}" />

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Success"
                Title="Running in the background"
                Message="Closing this window keeps PAWS running. Use the tray icon in the notification area to reopen or quit." />

            <TextBlock x:Name="AccountText" Style="{StaticResource BodyStrongTextBlockStyle}" />

            <TextBlock Text="Synced folders" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <ItemsControl x:Name="PairsList" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                <Button Content="Open local folder" Click="OnOpenFolderClicked" />
                <Button Content="Reconfigure" Click="OnReconfigureClicked" />
                <Button Content="Sign out" Click="OnSignOutClicked" />
            </StackPanel>

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Preview build"
                Message="Authentication uses a stub (no real Proton connection yet) and syncing is not active. This screen confirms setup and that credentials were stored securely." />
        </StackPanel>
    </ScrollViewer>
</Page>

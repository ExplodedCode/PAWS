<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PAWS.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="40,32,40,24" Spacing="20" MaxWidth="840" HorizontalAlignment="Center">

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Click="OnBackClicked" VerticalAlignment="Center" ToolTipService.ToolTip="Back to folders">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- App behavior -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="App behavior" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Preferences are saved now; full wiring lands in an upcoming build."
                        FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                    <ToggleSwitch
                        x:Name="StartupToggle"
                        Header="Start PAWS when you sign in to Windows"
                        Toggled="OnBehaviorToggled" />
                    <ToggleSwitch
                        x:Name="BackgroundToggle"
                        Header="Keep running in the background when closed or minimized"
                        Toggled="OnBehaviorToggled" />
                    <ToggleSwitch
                        x:Name="AutoSyncStartToggle"
                        Header="Start syncing all accounts when PAWS starts"
                        Toggled="OnBehaviorToggled" />
                </StackPanel>
            </Border>

            <!-- Sync speed -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Sync speed" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Cap how much of your connection PAWS uses. Limits are saved now and will take effect once the transfer throttle ships in an upcoming build."
                        FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="16" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ToggleSwitch
                            x:Name="UploadLimitToggle"
                            Header="Limit upload speed"
                            Toggled="OnUploadLimitToggled" />
                        <NumberBox
                            x:Name="UploadLimitBox"
                            Grid.Column="1"
                            Header="KB/s"
                            Minimum="16"
                            Maximum="1000000"
                            SmallChange="128"
                            SpinButtonPlacementMode="Compact"
                            MinWidth="140"
                            VerticalAlignment="Bottom"
                            IsEnabled="False"
                            ValueChanged="OnLimitValueChanged" />

                        <ToggleSwitch
                            x:Name="DownloadLimitToggle"
                            Grid.Row="1"
                            Header="Limit download speed"
                            Toggled="OnDownloadLimitToggled" />
                        <NumberBox
                            x:Name="DownloadLimitBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Header="KB/s"
                            Minimum="16"
                            Maximum="1000000"
                            SmallChange="128"
                            SpinButtonPlacementMode="Compact"
                            MinWidth="140"
                            VerticalAlignment="Bottom"
                            IsEnabled="False"
                            ValueChanged="OnLimitValueChanged" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Reset -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Reset" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock
                        Text="Signs out every account and removes all folder sync configurations from this PC. Your files are not deleted — everything on your PC and on Proton Drive stays where it is."
                        FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    <Button
                        x:Name="ResetButton"
                        Content="Reset app…"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                        Click="OnResetClicked"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
